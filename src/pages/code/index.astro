---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { getCollection } from "astro:content";

const codeEntries = await getCollection("code", ({ data }) => !data.draft);
---

<Layout title={`Code | ${SITE.title}`}>
  <Header activeNav="lesson" />
  <Main
    pageTitle="Code"
    pageDesc="Conteúdo sobre programação e desenvolvimento de software."
  >
    <div class="code-container">
      <div class="code-grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
        {codeEntries.map(entry => (
          <article class="code-card">
            <a href={`/code/${entry.slug}/`} class="code-link">
              <h2 class="code-title">{entry.data.title}</h2>
              {entry.data.description && (
                <p class="code-description">{entry.data.description}</p>
              )}
              {entry.data.category && (
                <span class="code-category">{entry.data.category}</span>
              )}
              <div class="code-tags">
                {entry.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          </article>
        ))}
      </div>
      {codeEntries.length === 0 && (
        <div class="empty-state">
          <p>Nenhum conteúdo de código encontrado.</p>
        </div>
      )}
    </div>
  </Main>
  <Footer />
</Layout>

<style>
  .code-container {
    @apply space-y-8;
  }
  
  .code-grid {
    @apply grid gap-6;
  }
  
  .code-card {
    @apply rounded-lg border p-6 transition-all hover:shadow-lg;
    @apply border-skin-line bg-skin-card;
  }
  
  .code-link {
    @apply block space-y-3;
  }
  
  .code-title {
    @apply text-xl font-semibold text-skin-base hover:text-skin-accent;
  }
  
  .code-description {
    @apply text-sm text-skin-base opacity-70 line-clamp-3;
  }
  
  .code-category {
    @apply inline-block rounded-full bg-skin-accent px-3 py-1 text-xs font-medium text-skin-inverted;
  }
  
  .code-tags {
    @apply flex flex-wrap gap-2;
  }
  
  .tag {
    @apply rounded bg-skin-fill px-2 py-1 text-xs text-skin-base opacity-70;
  }
  
  .empty-state {
    @apply text-center py-12 text-skin-base opacity-70;
  }
</style>
