---
import { SITE } from "@config";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import PDFConverterIsland from "@components/pdf/PDFConverterIsland";
---

<Layout title={`PDF para PNG | ${SITE.title}`}>
  <Header activeNav="lab" />
  <Main
    pageTitle="PDF para PNG"
    pageDesc="Converte páginas de PDF para imagens PNG ou extrai imagens incorporadas. Todo o processamento acontece no teu navegador - sem envios para qualquer servidor."
  >
    <PDFConverterIsland client:only="react" />
  </Main>
  <Footer />
</Layout>
